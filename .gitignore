# ── Security: credentials & secrets (standard block) ─────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
credentials*.json
secrets/
.secret

# RStudio project files (personal IDE config — not code)
.Rproj.user/
pmatools.Rproj
*.Rproj

# R session artifacts
.Rhistory
.RData
.Ruserdata

# Generated output (reproduced by sample.R)
outputs/

# R binary data objects (regenerated via data-raw/cbti_depression.R)
data/*.rda
# Exception: bundled sample data must ship with the package
!data/cbti_depression.rda

# Manuscript (local only — not for public repo)
manuscript/
pmatools_campbell_draft.docx

# Drafts (specs not ready for the public repo)
gitignore/
